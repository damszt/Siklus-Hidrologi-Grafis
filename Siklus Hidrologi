<script>
const details = {
  1: {
    title: "☀️ Evaporasi (Penguapan)",
    body: "Evaporasi adalah proses penguapan air dari badan air seperti laut, danau, dan sungai ke atmosfer. Proses ini terjadi akibat panas matahari yang memanaskan permukaan air hingga berubah menjadi uap air dan naik ke atas.",
    fact: "💡 Tahukah kamu? Sekitar 86% evaporasi global berasal dari lautan! Suhu yang lebih tinggi mempercepat laju penguapan."
  },
  2: {
    title: "🌤️ Kondensasi (Pembentukan Awan)",
    body: "Kondensasi adalah perubahan wujud uap air menjadi titik-titik air cair karena penurunan suhu di atmosfer. Titik-titik air yang sangat kecil ini berkumpul membentuk awan dan kabut yang kita lihat di langit.",
    fact: "💡 Awan cumulus putih yang indah terbentuk dari jutaan butiran air berukuran 1–100 mikrometer — lebih kecil dari rambut manusia!"
  },
  3: {
    title: "🌧️ Presipitasi (Hujan/Salju)",
    body: "Presipitasi adalah proses jatuhnya air dari atmosfer ke permukaan bumi. Bentuknya bisa bermacam-macam: hujan (di daerah tropis), salju (di daerah dingin), hujan es, atau embun. Di Indonesia, presipitasi dominan berupa hujan.",
    fact: "💡 Indonesia memiliki curah hujan 2.000–4.000 mm per tahun! Kita termasuk negara dengan curah hujan tertinggi di dunia."
  },
  4: {
    title: "🌱 Infiltrasi (Peresapan Tanah)",
    body: "Infiltrasi adalah proses peresapan air ke dalam tanah melalui pori-pori tanah. Air yang meresap menjadi air tanah (groundwater) yang bisa muncul kembali sebagai mata air atau sumur. Hutan dan tanah bervegetasi meningkatkan laju infiltrasi.",
    fact: "💡 Beton dan aspal kota mengurangi infiltrasi hingga 55%! Ini salah satu alasan mengapa banjir kota semakin sering terjadi."
  },
  5: {
    title: "🌊 Run Off (Limpasan Air)",
    body: "Run off adalah pergerakan air di permukaan tanah menuju tempat yang lebih rendah — sungai, danau, lalu berakhir di laut. Proses ini melengkapi siklus dan membawa air kembali ke lautan untuk menguap lagi.",
    fact: "💡 Pohon-pohon di tepi sungai (riparian forest) bisa mengurangi run off hingga 40% dan mencegah erosi tanah secara alami."
  }
};

function showTab(name, el) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('panel-' + name).classList.add('active');
  el.classList.add('active');
}

function showDetail(n) {
  document.querySelectorAll('.step-card').forEach(c => c.classList.remove('active'));
  document.getElementById('card-' + n).classList.add('active');
  const d = details[n];
  const box = document.getElementById('detail-box');
  box.style.display = 'block';
  box.innerHTML = `<h3>${d.title}</h3><p>${d.body}</p><div class="fun-fact">${d.fact}</div>`;
  box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}
</script>
